def cluster_locations_grid(df, cell_meters: float = 10):
    """
    Grid-based clustering — strict proximity, no chaining, O(n).
    Points snap to a fixed grid of cell_meters × cell_meters cells.
    No two points in different cells can be in the same cluster.
    Maximum distance between any two points in same cluster = cell_meters × √2 (~14m at 10m grid)
    """
    df = df.copy()

    # Convert cell size to degrees
    # 1 degree lat ≈ 111,320m everywhere
    # 1 degree lon ≈ 111,320m × cos(lat) — use mean lat
    mean_lat    = df["lat"].mean()
    lat_step    = cell_meters / 111_320
    lon_step    = cell_meters / (111_320 * np.cos(np.radians(mean_lat)))

    # Snap each point to nearest grid cell
    df["grid_lat"] = (df["lat"] / lat_step).round().astype(int)
    df["grid_lon"] = (df["lon"] / lon_step).round().astype(int)

    # Assign cluster ID from grid cell
    grid_keys  = df[["grid_lat", "grid_lon"]].apply(tuple, axis=1)
    unique_cells = {cell: idx for idx, cell in enumerate(grid_keys.unique())}
    df["location_id"] = grid_keys.map(unique_cells)

    # Centroid label per cluster
    centers = df.groupby("location_id")[["lat", "lon"]].mean()
    label_map = {
        cid: f"({row['lat']:.5f}, {row['lon']:.5f})"
        for cid, row in centers.iterrows()
    }
    df["location_label"] = df["location_id"].map(label_map)
    df.drop(columns=["grid_lat", "grid_lon"], inplace=True)
    return df
